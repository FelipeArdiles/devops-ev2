# Copia este archivo a deploy.env y ajusta si hace falta:
#   cp scripts/deploy.env.example scripts/deploy.env
#
# deploy.env está en .gitignore (no subas contraseñas a GitHub).

AWS_REGION=us-east-1
PROJECT_NAME=devops-u2
CLUSTER_NAME=devops-u2-cluster
SERVICE_NAME=app

DB_USER=root
DB_PASSWORD=root
DB_NAME=proyecto_db
KEY_PAIR_NAME=vockey

# Minutos máximos de espera
MYSQL_READY_TIMEOUT=300
ECS_READY_TIMEOUT=600
